[alias]
	# helper
	ingitbash = !uname -s | grep ^MINGW >/dev/null
	ingitcmd = !uname -s | grep ^MSYS >/dev/null
	ingitwindows = "!f() { if git ingitbash || git ingitcmd; then return 0; else return 1; fi; }; f"
	configtype = "!f() { \
		git ingitbash && echo git-bash; \
		git ingitcmd && echo cmd; \
		git ingitwindows && echo windows; \
		git ingitwindows || echo unix; \
	}; f"
	haveman = !which man >/dev/null 2>&1
	havepandoc = !which pandoc >/dev/null 2>&1
	slashsuperroot = "!f() { if git ingitbash; then git superroot | sed \"s,\\(.\\):/,/\\L\\1/,\"; else git superroot; fi; }; f"
	# color
	ccyan = "!f() { git ingitwindows && echo \"[36m\" || printf \"\\033[96;1;1m\"; }; f"
	cgray = "!f() { git ingitwindows && echo \"[37m\" || printf \"\\033[90;1;1m\"; }; f"
	cgreen = "!f() { git ingitwindows && echo \"[32m\" || printf \"\\033[92;1;1m\"; }; f"
	cmagenta = "!f() { git ingitwindows && echo \"[35m\" || printf \"\\033[95;1;1m\"; }; f"
	cred = "!f() { git ingitwindows && echo \"[31m\" || printf \"\\033[31;1;1m\"; }; f"
	cyellow = "!f() { git ingitwindows && echo \"[33m\" || printf \"\\033[93;1;1m\"; }; f"
	cnone = "!f() { git ingitwindows && echo \"[0m\" || printf \"\\033[0m\"; }; f"
	# echo
	hilite = "!f() { echo $(git cyellow)$*$(git cnone); }; f"
	error = "!f() { echo $(git cred)$*$(git cnone); }; f"
	extra = "!f() { echo $(git cmagenta)$*$(git cnone); }; f"
	header = "!f() { echo $(git cgreen)$*$(git cnone); }; f"
	info = "!f() { echo $(git ccyan)$*$(git cnone); }; f"
	prerror = "!f() { echo $(git error '!!!' $*); }; f"
	prextra = "!f() { echo $(git extra [git $*]); }; f"
	prheader = "!f() { echo $(git header '>>>'); }; f"
	prinfo = "!f() { echo $(git info '---'); }; f"
	prnl = "!f() { printf \"%s\\12\" \"$@\"; }; f"
	# misc
	headco = "!f() { : ; \
		if [ \"$(git lname HEAD)\" = \"$(git lname $(git mainmaster))\" ]; then : ; \
			git co $(git mainmaster); : ; \
			return 0; : ; \
		fi; \
		branch=\"\"; : ; \
		for i in $(git for-each-ref --format=\"%(refname:short)\" refs/heads/); do : ; \
			[ \"$(git lname HEAD)\" = \"$(git lname $i)\" ] || continue; : ; \
			if [ ! -z \"$branch\" ]; then : ; \
				>&2 echo headco: HEAD could be on \\\"$branch\\\" or \\\"$i\\\".; : ; \
				return 1; : ; \
			fi; \
			branch=$i; : ; \
		done; \
		if [ ! -z \"$branch\" ]; then : ; \
			git co $branch; : ; \
			return 0; : ; \
		fi; \
		>&2 echo headco: HEAD is not on a branch.; : ; \
	}; f"
	# bundle
	verifybundle = "!f() { \
		[ $# -gt 1 ] && echo Usage: verifybundle filename && return 1; : Ensure proper number of arguments; \
		git bundle verify \"${1:-$(git broot).bundle}\";               : Call git bundle with proper filename; \
		return 0;                                                      : Return zero; \
	}; f"
	removebundle = "!f() { \
		[ $# -gt 1 ] && echo Usage: removebundle filename && return 1; : Ensure proper number of arguments; \
		rm \"${1:-$(git broot).bundle}\";                              : Call rm with proper filename; \
		return 0;                                                      : Return zero; \
	}; f"
	createbundle = "!f() { \
		[ $# -lt 1 -o $# -gt 2 ] && echo Usage: createbundle since filename && return 1; : Ensure proper number of arguments; \
		git bundle create \"${2:-$(git broot).bundle}\" --since=\"$1\" --all;            : Call git bundle with proper arguments; \
		return 0;                                                                        : Return zero; \
	}; f"
	fetchbundle = "!f() { \
		[ $# -gt 1 ] && echo Usage: fetchbundle filename && return 1; : Ensure proper number of arguments; \
		git fetch -u \"${1:-$(git broot).bundle}\" \"refs/*:refs/*\"; : Fetch from bundle and keep refs; \
		git rhard;                                                    : Return working copy to blank slate; \
		IFS=\"\n\";                                                   : Use newline as separator; \
		for remote in $(git remotebranches | grep -vE HEAD); do       : Iterate over all remote branches; \
			git co ${remote#*/};                                      : Checkout local branch corresponding to remote branch; \
			git branch -u ${remote/  /};                              : Set the upstream for the local branch; \
		done; \
		git co $(git mainmaster);                                     : Return to main branch; \
		return 0;                                                     : Return zero; \
	}; f"
	combinebundles = "!f() { \
		[ $# -lt 1 -o $# -gt 2 ] && echo Usage: combinebundles tarfile rootname && return 1; : Ensure proper number of arguments; \
		tarfile=\"$1\";                                                                      : Set the output filename; \
		bname=\"${2:-$(git broot).bundle}\";                                                 : Set the toplevel name; \
		tar cvf \"$tarfile\" \"$bname\";                                                     : Archive the toplevel bundle; \
		rm \"$bname\";                                                                       : Remove the toplevel bundle; \
		IFS=\"\n\";                                                                          : Use newline as separator; \
		for i in $(git lssubmodules); do                                                     : Iterate over all submodules; \
			if [ -e \"$i/$i.bundle\" ]; then                                                 : If a bundle exists; \
				tar rvf \"$tarfile\" \"$i/$i.bundle\";                                       : Add bundle to output file; \
				rm \"$i/$i.bundle\";                                                         : Remove the bundle; \
			fi; \
		done; \
		return 0;                                                                            : Return zero; \
	}; f"
	uncombinebundles = "!f() { \
		[ $# -lt 1 -o $# -gt 2 ] && echo Usage: uncombinebundles tarfile rootname && return 1; : Ensure proper number of arguments; \
		tarfile=\"$1\";                                                                        : Set the input filename; \
		bname=\"${2:-$(git broot).bundle}\";                                                   : Set the toplevel name; \
		tar xvf \"$tarfile\" \"$bname\";                                                       : Extract the toplevel bundle; \
		IFS=\"\n\";                                                                            : Use newline as separator; \
		for i in $(git lssubmodules); do                                                       : Iterate over all submodules; \
			tar xvf \"$tarfile\" \"$i/$i.bundle\";                                             : Extract bundle; \
		done; \
		return 0;                                                                              : Return zero; \
	}; f"
	# attributes
	repeatstr = "!f() { printf \"%0.s${2:- }\" $($SHELL -c \"echo {1..$1}\"); }; f"
	genattributes = "!f() { \
		if [ $# -lt 1 ]; then \
			echo Usage: genattributes attribute [maxlen]; \
			return 1; \
		fi; \
		command=\"lscaunspecified $1\"; \
		repl=\": $1: unspecified\"; \
		if [ $# -gt 1 ]; then \
			maxlen=$2; \
		elif git $command >/dev/null 2>&1; then \
			maxlen=$(git $command | awk '{ print length }' | sort -n | tail -1); \
			maxlen=$(expr $maxlen - ${#repl} + 2); \
		else return 0; \
		fi; \
		git $command | while read line; do \
			line=$(echo \"$line\" | sed \"s<$repl<<\"); \
			left=$(expr $maxlen - ${#line}); \
			printf '%s%s%s\\12' \"$line\" \"$(git repeatstr $left)\" text; \
		done; \
	}; f"
	filetype = "!f() { : git man filetype; \
		command() { git ls-files -z | xargs -0 file; }; : Base command, file, to run; \
		if [ $# -gt 0 ]; then command | grep \"$@\";    : If arguments, filter through grep; \
		else command; fi;                               : If not, just output; \
	}; f"
	mimetype = "!f() { : git man mimetype; \
		command() { git ls-files -z | xargs -0 file --mime; }; : Base command, file --mime, to run; \
		if [ $# -gt 0 ]; then command | grep \"$@\";           : If arguments, filter through grep; \
		else command; fi; :                                    : If not, just output; \
	}; f"
	nonascii = "!f() { : git man nonascii; \
		if type pcregrep >/dev/null 2>&1; then command=pcregrep; : Use pcregrep command if available; \
		else command=\"grep -P\"; fi;                            : Else use grep -P; \
		$command --color=auto -n \"[^\\x0-\\x7f]\" \"$@\";       : Execute command to print non-ascii characters; \
	}; f"
	nonasciiall = "!f() { : git man nonasciiall; \
		git notasciilist | tr \"\\12\" \"\\0\" | xargs -0 git nonascii; : List all files with non-ascii characters and print those characters; \
	}; f"
	gitbinary = "!f() { : git man gitbinary; \
		git diff $(git empty) --numstat HEAD -- \"$@\" | grep ^- | cut -f 3; : List git binary files; \
	}; f"
	gittext = "!f() { : git man gittext; \
		git diff $(git empty) --numstat HEAD -- \"$@\" | grep -v ^- | cut -f 3; : List git text files; \
	}; f"
	charsets = "!f() { : git man charsets; \
		types='binary us-ascii utf-8 iso-8859-1 unknown-8bit utf-16le utf-16be ebcdic'; : All the charsets likely to be encountered; \
		maxlen=20;                                                                      : Minimum spacing on output; \
		for type in $types; do                                                          : Loop over likely charsets; \
			count=$(git mimetype $type | wc -l);                                        : Count number of files of that charset; \
			left=$(expr $maxlen - ${#type});                                            : Find spacing required; \
			printf '%s%s%d\\12' $type \"$(git repeatstr $left)\" $count;                : Print out the count with spacing; \
		done;                                                                           : Done with charset; \
	}; f"
	forceeol = "!f() { : git man forceeol; \
		LOCALFILE=.git/info/attributes;                                     : Filename to write to; \
		if [ $# -ne 2 ]; then echo Usage: forceeol match eol; return 1; fi; : Ensure proper number of arguments; \
		grep \"$1 text eol=$2\" $LOCALFILE >/dev/null 2>&1 && return;       : Ensure that config has not already been set \
		echo \"$1\" text eol=$2 | tee -a $LOCALFILE;                        : Write the attribute to the proper local file; \
	}; f"
	resetperms = "!f() { \
		git diff -p -R --no-ext-diff --no-color | grep -E \"^(old|new) mode\" >/dev/null 2>&1 || return 0;      : Return if no mode changes; \
		git diff -p -R --no-ext-diff --no-color | grep -E \"^(diff|(old|new) mode)\" --color=never | git apply; : Apply reverse patch to fix permissions; \
	}; f"
	# config
	globalhookspath = "!f() { : git man globalhookspath; \
		LOCALFILE=~/gitconfig/local;                                                 : Filename to write to; \
        grep 'hooksPath=\"~/gitconfig/hooks\"' $LOCALFILE >/dev/null 2>&1 && return; : Ensure that config has not already been set; \
		echo '' >> $LOCALFILE;                                                       : Output a newline; \
		echo '[core]' >> $LOCALFILE;                                                 : Output start of section; \
        echo '\thooksPath=\"~/gitconfig/hooks\"' >> $LOCALFILE;                      : Output hooksPath configuration; \
    }; f"
	insteadof = "!f() { \
		LOCALFILE=~/gitconfig/localschemes;                        : Filename to write to; \
		[ $# -ne 2 ] && echo Usage: insteadOf from to && return 1; \
		git config --file $LOCALFILE url.\"$2\".insteadOf \"$1\"; \
	}; f"
	man = "!f() { : git man man; \
		[ $# -ne 1 ] && echo Usage: man command && return 1;                                    : Ensure proper number of arguments; \
		command() { sed '/D.*E.*T.*A.*I.*L.*S/q' | sed '$d' | grep -v '^$'; };                  : Command to prune off DETAILS section; \
		docpath=~/gitconfig/man;                                                                : Where man pages are kept; \
		htmlpath=~/gitconfig/html;                                                              : Where html pages are kept; \
		if git ingitbash; then                                                                  : Check if using git-bash; \
			docpath=$(cygpath -m $docpath);                                                     : Change to windows path with forward slashes; \
			htmlpath=$(cygpath -m $htmlpath);                                                   : Change to windows path with forward slashes; \
		fi;                                                                                     : Close if statement; \
		if git vartrue dohtml; then git web--browse \"$htmlpath/git-$1.html\";                  : If should do html, open web browser; \
		elif git haveman; then                                                                  : If should man pages, then; \
			export MANPATH=$docpath;                                                            : Set environment variable for man execution; \
			man git-$1 | tail -n +2 | command;                                                  : Execute man without uninteresting parts; \
		elif git havepandoc; then pandoc -f man \"$docpath/man1/git-$1.1\" -t plain | command;  : If pandoc is available, try to output man page; \
        else cat \"$docpath/man1/git-$1.1\" | sed 's,^\\.SH ,,' | grep -v '^\\.' | command; fi; : Cat the file as a last resort; \
	} ; f"
	# gpg
	catf = "!f() { git cat-file commit ${1:-HEAD}; }; f"
	hashes = "!f() { echo $(git log --oneline ${1:-HEAD} --pretty=format:\"%h\"); }; f"
	gpgpush = "!f() { git push ${1:-origin} refs/notes/gpg; }; f"
	gpgpull = "!f() { \
		echo $(git prheader) $(git hilite gpgpull);                  : Output command header; \
		if ! git attached; then return 1; fi;                        : Ensure that HEAD is not detached HEAD; \
		PREV=$(git ref);                                             : Store ref of HEAD; \
		cmd=\"checkout refs/notes/gpg\";                             : Set next command; \
		echo $(git prinfo) checkout gpg $(git prextra $cmd);         : Output next command; \
		git $cmd >/dev/null 2>&1;                                    : Download changesets from origin remote; \
		cmd=\"fetch ${1:-origin} refs/notes/gpg:refs/notes/gpg\";    : Set next command; \
		echo $(git prinfo) fetch gpg $(git prextra $cmd);            : Output next command; \
		git $cmd >/dev/null 2>&1;                                    : Download changesets from origin remote; \
		cmd=\"checkout refs/notes/gpg\";                             : Set next command; \
		echo $(git prinfo) checkout gpg $(git prextra $cmd);         : Output next command; \
		git $cmd >/dev/null 2>&1;                                    : Download changesets from origin remote; \
		if ! git stow; then return 1; fi;                            : Call stow alias to temporarily store Workspace; \
		cmd=\"rebase FETCH_HEAD\";                                   : Set next command; \
		echo $(git prinfo) rebase gpg $(git prextra $cmd);           : Output next command; \
		git $cmd;                                                    : Download changesets from origin remote; \
		for file in $(git diff --name-only --diff-filter=U); do      : ; \
			git show :2:$file :3:$file > $file;                      : ; \
		done;                                                        : ; \
		cmd=\"add .\";                                               : Set next command; \
		echo $(git prinfo) add concatenated gpg $(git prextra $cmd); : Output next command; \
		git $cmd;                                                    : Download changesets from origin remote; \
		cmd=\"commit -m Notes\";                                     : Set next command; \
		echo $(git prinfo) commit rebase $(git prextra $cmd);        : Output next command; \
		git $cmd;                                                    : Download changesets from origin remote; \
		cmd=\"rebase --skip\";                                       : Set next command; \
		echo $(git prinfo) skip $(git prextra $cmd);                 : Output next command; \
		git $cmd >/dev/null 2>&1;                                    : Download changesets from origin remote; \
		cmd=\"update-ref refs/notes/gpg HEAD\";                      : Set next command; \
		echo $(git prinfo) update-ref on gpg $(git prextra $cmd);    : Output next command; \
		git $cmd;                                                    : Download changesets from origin remote; \
		cmd=\"checkout $PREV\";                                      : Set next command; \
		echo $(git prinfo) checkout $PREV $(git prextra $cmd);       : Output next command; \
		git $cmd;                                                    : Download changesets from origin remote; \
		git unstow;                                                  : Call unstow alias to restore Workspace to former condition; \
		return 0;                                                    : Return zero; \
	}; f"
	gpggpg = "!f() { \
		git catf ${1:-HEAD} | gpg --detach-sign --armor; \
	}; f"
	gpgsign = "!f() { \
		rev=${1:-HEAD}; \
		git gpggpg $rev | tee /dev/stderr | git notes --ref gpg append -F - $rev; \
	}; f"
	gpgunsign = "!f() { \
		[[ $# -ne 2 ]] && echo Usage: gpgunsign revision pattern && return 1; \
		rev=$1; \
		pattern=$2; \
		git gpgsigns $rev |  awk -v PATTERN=$pattern 'BEGIN { RS=\"-----BEGIN PGP SIGNATURE-----\" } \
			{ if (!match($0, PATTERN) && match($0, \"END PGP SIGNATURE\")) { print RS; print } }' \
			| git notes --ref gpg add -f -F - $rev; \
	}; f"
	gpgsigns = "!f() { \
		git notes --ref gpg show ${1:-HEAD}; \
	}; f"
	gpgsignkeys = "!f() { \
		git gpgsigns ${1:-HEAD} | gpg --list-packets | grep ID | sed 's,.*issuer key ID ,,' | sed 's,),,'; \
	}; f"
	gpgverify = "!f() { \
		rev=${1:-HEAD}; \
		bash -c \"git catf $rev | gpg --verify <(git gpgsigns $rev) -\" 2>&1; \
	}; f"
	gpgverifyall = "!f() { : git man gpgverifyall; \
		rv=\"\"; \
		for rev in $(git hashes); do \
			echo \"=== $rev ===\"; \
			if ! git gpgverify $rev; then rv=\"$rv $rev\"; fi; \
		done; \
		echo $rv | tee /dev/stderr >/dev/null; \
	}; f"
	gpgverifysum = "!f() { git gpgverifyall >/dev/null; }; f"
	# diff
	dir = "!f() { \
		if [ $# -gt 0 ]; then rev=$1; shift; fi; \
		git di ${rev:-HEAD}^..${rev:-HEAD} \"$@\"; \
	}; f"
	dtr = "!f() { \
		if [ $# -gt 0 ]; then rev=$1; shift; fi; \
		git dt ${rev:-HEAD}^..${rev:-HEAD} \"$@\"; \
	}; f"
	dtkr = "!f() { \
		if [ $# -gt 0 ]; then rev=$1; shift; fi; \
		git dtk -d ${rev:-HEAD}^..${rev:-HEAD} \"$@\"; \
	}; f"
	dtmr = "!f() { \
		if [ $# -gt 0 ]; then rev=$1; shift; fi; \
		git dtm -d ${rev:-HEAD}^..${rev:-HEAD} \"$@\"; \
	}; f"
	dtir = "!f() { \
		if [ $# -gt 0 ]; then rev=$1; shift; fi; \
		git dti ${rev:-HEAD}^..${rev:-HEAD} \"$@\"; \
	}; f"
	dtvr = "!f() { \
		if [ $# -gt 0 ]; then rev=$1; shift; fi; \
		git dtv ${rev:-HEAD}^..${rev:-HEAD} \"$@\"; \
	}; f"
    # submodules
	smfone = "!f() { \
		[ $# -ne 1 ] && echo Usage: smfone command && return;       : Ensure proper number of arguments; \
		git sm $(git smflags) foreach $(git smforeachflags) \"$1\"; : Iterate; \
	}; f"
	smf = "!f() { : git man smf; \
		[ $# -lt 1 ] && echo Usage: smf command && return; : Ensure proper number of arguments; \
		: Iterate; \
		[ $# -eq 1 ] && git smfone \"$1; true\"; \
		[ $# -eq 2 ] && git sm $(git smflags) foreach $(git smforeachflags) \"\\\"$1\\\" \\\"$2\\\"; true\"; \
		[ $# -eq 3 ] && git sm $(git smflags) foreach $(git smforeachflags) \"\\\"$1\\\" \\\"$2\\\" \\\"$3\\\"; true\"; \
		[ $# -eq 4 ] && git sm $(git smflags) foreach $(git smforeachflags) \"\\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\"; true\"; \
		[ $# -eq 5 ] && git sm $(git smflags) foreach $(git smforeachflags) \"\\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\"; true\"; \
		[ $# -eq 6 ] && git sm $(git smflags) foreach $(git smforeachflags) \"\\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\" \\\"$6\\\"; true\"; \
		[ $# -eq 7 ] && git sm $(git smflags) foreach $(git smforeachflags) \"\\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\" \\\"$6\\\" \\\"$7\\\"; true\"; \
		[ $# -eq 8 ] && git sm $(git smflags) foreach $(git smforeachflags) \"\\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\" \\\"$6\\\" \\\"$7\\\" \\\"$8\\\"; true\"; \
		[ $# -eq 9 ] && git sm $(git smflags) foreach $(git smforeachflags) \"\\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\" \\\"$6\\\" \\\"$7\\\" \\\"$8\\\" \\\"$9\\\"; true\"; \
		[ $# -gt 9 ] && git sm $(git smflags) foreach $(git smforeachflags) \"$@\"; \
		return 0;                                          : Return zero; \
	}; f"
	smg = "!f() { : git man smg; \
		[ $# -lt 1 ] && echo Usage: smg command && return; : Ensure proper number of arguments; \
		git smf git \"$@\";                                : Iterate; \
		return 0;                                          : Return zero; \
	}; f"
	smfa = "!f() { : git man smfa; \
		[ $# -lt 1 ] && echo Usage: smfa command && return; : Ensure proper number of arguments; \
		git smf \"$@\";                                     : Iterate; \
		git vartrue smquiet || echo Entering \\'.\\';       : Output current path; \
		\"$@\";                                             : Execute in container; \
		return 0;                                           : Return zero; \
	}; f"
	smga = "!f() { : git man smga; \
		[ $# -lt 1 ] && echo Usage: smga command && return; : Ensure proper number of arguments; \
		git smg \"$@\";                                     : Iterate; \
		git vartrue smquiet || echo Entering \\'.\\';       : Output current path; \
		git \"$@\";                                         : Execute in container; \
		return 0;                                           : Return zero; \
	}; f"
	fismf = "!f() { \
		[ $# -lt 2 ] && echo Usage: fsmf filter command && return;                  : Ensure proper number of arguments; \
		filter=$(eval $1 | sed 's,.*,\"&\",' | tr \"\\12\" \"|\" | sed s,\"|\"$,,); : Filter to convert newlines to pipes; \
		shift;                                                                      : Drop filter from remaining arguments; \
		if echo $filter | grep ^$ >/dev/null 2>&1; then                             : If filter does not generate any matches ; \
			git smf true;                                                           : Iterate and apply noop; \
		else                                                                        : Else filter matches at least one submodule; \
			: Iterate with filter and apply command; \
			[ $# -eq 1 ] && git smfone \"case \\$name in $filter) $1; true;; esac\"; \
			[ $# -eq 2 ] && git smfone \"case \\$name in $filter) \\\"$1\\\" \\\"$2\\\"; true;; esac\"; \
			[ $# -eq 3 ] && git smfone \"case \\$name in $filter) \\\"$1\\\" \\\"$2\\\" \\\"$3\\\"; true;; esac\"; \
			[ $# -eq 4 ] && git smfone \"case \\$name in $filter) \\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\"; true;; esac\"; \
			[ $# -eq 5 ] && git smfone \"case \\$name in $filter) \\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\"; true;; esac\"; \
			[ $# -eq 6 ] && git smfone \"case \\$name in $filter) \\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\" \\\"$6\\\"; true;; esac\"; \
			[ $# -eq 7 ] && git smfone \"case \\$name in $filter) \\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\" \\\"$6\\\" \\\"$7\\\"; true;; esac\"; \
			[ $# -eq 8 ] && git smfone \"case \\$name in $filter) \\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\" \\\"$6\\\" \\\"$7\\\" \\\"$8\\\"; true;; esac\"; \
			[ $# -eq 9 ] && git smfone \"case \\$name in $filter) \\\"$1\\\" \\\"$2\\\" \\\"$3\\\" \\\"$4\\\" \\\"$5\\\" \\\"$6\\\" \\\"$7\\\" \\\"$8\\\" \\\"$9\\\"; true;; esac\"; \
			[ $# -gt 9 ] && git smfone \"case \\$name in $filter) $*; true;; esac\"; \
		fi; \
		return 0;                                                                   : Return zero; \
