.SH NAME
.PP
git backups
.SH SYNOPSIS
.PP
git backups - list available backups from previous backup invocations
.SH DESCRIPTION
.PP
git backups is a helper alias to list available backups from previous
backup invocations.
.SH EXAMPLES
.IP \[bu] 2
git backups
.SH SEE ALSO
.PP
backup backuprm
.SH DETAILS
.IP
.nf
\f[C]
backups = \[dq]!f() { : git man backups; \[rs]
    bn=$(basename $(pwd)); \[rs]
    ls -ldhtr ../$bn.*.tar; \[rs]
}; f\[dq]
\f[R]
