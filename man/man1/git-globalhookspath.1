.TH "git alias.globalhookspath(1) User manual" "" "May, 2020" "" ""
.hy
.SH NAME
.PP
git globalhookspath
.SH SYNOPSIS
.PP
git globalhookspath - add core.hooksPath to \[ti]/gitconfig/local
.SH DESCRIPTION
.PP
git globalhookspath is a helper alias to add
core.hooksPath=$HOME/gitconfig/hooks to $HOME/gitconfig/local.
.SH EXAMPLES
.IP \[bu] 2
git globalhookspath
.SH DETAILS
.IP
.nf
\f[C]
globalhookspath = \[dq]!f() { : git man globalhookspath; \[rs]
        LOCALFILE=\[ti]/gitconfig/local; \[rs]
        grep \[aq]hooksPath=\[rs]\[dq]\[ti]/gitconfig/hooks\[rs]\[dq]\[aq] $LOCALFILE >/dev/null && return 1; \[rs]
        echo \[aq]\[aq] >> $LOCALFILE; \[rs]
        echo \[aq][core]\[aq] >> $LOCALFILE; \[rs]
        echo \[aq]\[rs]thooksPath=\[rs]\[dq]\[ti]/gitconfig/hooks\[rs]\[dq]\[aq] >> $LOCALFILE; \[rs]
    }; f\[dq]
\f[R]
.fi
