.TH "git alias.stowcob(1)" "" "" "" ""
.hy
.SH NAME
.PP
git stowcob
.SH SYNOPSIS
.PP
git stowcob branch - stow working copy, checkout first argument that
tracks second argument, then unstow
.SH DESCRIPTION
.PP
git stowcob is a helper alias to stow the working copy changes, checkout
a new branch that tracks another branch, then unstow the working copy
changes.
.IP "1." 3
Ensures that the proper number of arguments have been provided
.IP "2." 3
Calls the stow alias to temporarily store the Workspace
.IP "3." 3
Checks out the target branch with the proper tracking branch
.IP "4." 3
Calls the unstow alias to restore the Workspace to its former condition
.SH EXAMPLES
.IP \[bu] 2
\f[C]git stowcob $(git brupstream)\f[R]
.IP \[bu] 2
\f[C]git stowcob master\f[R]
.SH SEE ALSO
.PP
stowco stow unstow
.SH DETAILS
.IP
.nf
\f[C]
stowcob = \[dq]!f() { : git man stowcob; \[rs]
    echo $(git prheader) $(git emph stowcob);                              : Output command header; \[rs]
    [ $# -ne 2 ] && echo Usage: stowco branch tracking && return 1;        : Ensure proper number of arguments; \[rs]
    if ! git stow; then return 1; fi;                                      : Call stow alias to temporarily store Workspace; \[rs]
    cmd=\[rs]\[dq]checkout -b $1 $2\[rs]\[dq];                                             : Set next command; \[rs]
    echo $(git prinfo) checkout $1 branch tracking $2 $(git prextra $cmd); : Output next command; \[rs]
    git $cmd;                                                              : Check out target branch with proper tracking branch; \[rs]
    git unstow;                                                            : Call unstow alias to restore Workspace to former condition; \[rs]
    return 0;                                                              : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
