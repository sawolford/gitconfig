.TH "git alias.rewindbase(1)" "" "" "" ""
.hy
.SH NAME
.PP
git rewindbase
.SH SYNOPSIS
.PP
git rewindbase source - move a branch to the common ancestor with its
upstream
.SH DESCRIPTION
.PP
git rewindbase is a helper alias to force move a branch to the common
ancestor with its upstream.
.IP "1." 3
Ensures that the proper number of arguments have been provided
.IP "2." 3
Ensures that the provided argument is associated with a branch
.IP "3." 3
Ensures that the provided branch is associated with an upstream branch
.IP "4." 3
Stores the upstream branch name associated with HEAD in a variable
.IP "5." 3
Finds and stores the merge base between the provided branch and its
upstream
.IP "6." 3
Calls branch -f to force the provided branch pointer back to its common
base with its upstream
.SH EXAMPLES
.IP \[bu] 2
\f[C]git rewindbase master\f[R]
.SH SEE ALSO
.SH DETAILS
.IP
.nf
\f[C]
rewindbase = \[dq]!f() { : git man rewindbase; \[rs]
    echo $(git prheader) $(git emph rewindbase);                            : Output command header; \[rs]
    [ $# -ne 1 ] && echo Usage: rewindbase source && return 1;              : Ensure proper number of arguments; \[rs]
    if ! git sref $1; then return 1; fi;                                    : Ensure that provided argument is associated with branch; \[rs]
    cmd=\[rs]\[dq]rev-parse --abbrev-ref $1\[at]{u}\[rs]\[dq];                                  : Set next command; \[rs]
    echo $(git prinfo) check for upstream on $1 branch $(git prextra $cmd); : Output next command; \[rs]
    if ! git $cmd >/dev/null 2>&1; then                                     : Ensure that provided branch is associated with upstream branch; \[rs]
        echo $(git prerror branch $1 has no upstream);                      : Error if current branch is not associated with upstream branch; \[rs]
        return 1;                                                           : Return error code; \[rs]
    fi;                                                                     : Close if statement; \[rs]
    UPSTREAM=$(git rev-parse --abbrev-ref $1\[at]{u});                          : Store upstream branch name associated with HEAD in variable; \[rs]
    BASE=$(git rev-parse --short $(git merge-base $1 $UPSTREAM));           : Store merge base between provided branch and upstream; \[rs]
    cmd=\[rs]\[dq]branch -f $1 $BASE\[rs]\[dq];                                             : Set next command; \[rs]
    echo $(git prinfo) move branch $1 to $BASE $(git prextra $cmd);         : Output next command; \[rs]
    git $cmd;                                                               : Force provided branch back to common base with upstream; \[rs]
    return 0;                                                               : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
