.TH "git alias.pickfrom(1) User manual" "" "May, 2020" "" ""
.hy
.SH NAME
.PP
git pickfrom
.SH SYNOPSIS
.PP
git pickfrom branch - stow working copy, cherrypick changesets, then
unstow
.SH DESCRIPTION
.PP
git pickfrom is a helper alias to cherrypick changesets from another
branch onto HEAD.
.SH EXAMPLES
.IP \[bu] 2
git pickfrom branch
.SH SEE ALSO
.PP
rebasefrom finishfrom mergefrom
.SH DETAILS
.IP
.nf
\f[C]
pickfrom = \[dq]!f() { : git man pickfrom; \[rs]
    [ $# -ne 1 ] && echo \[aq]Usage: pickfrom revision(s)\[aq] && return 1; \[rs]
    if ! git stow; then return 1; fi; \[rs]
    git cherry-pick $1; \[rs]
    git mt; \[rs]
    git commit; \[rs]
    git unstow; \[rs]
}; f\[dq]
\f[R]
.fi
