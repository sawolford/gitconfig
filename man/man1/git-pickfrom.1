.SH NAME
.PP
git pickfrom
.SH SYNOPSIS
.PP
git pickfrom branch - stow working copy, cherrypick changesets, then
unstow
.SH DESCRIPTION
.PP
git pickfrom is a helper alias to cherrypick changesets from another
branch onto HEAD.
.SH EXAMPLES
.IP \[bu] 2
\f[C]git pickfrom branch\f[R]
.SH SEE ALSO
.PP
rebasefrom finishfrom mergefrom
.SH DETAILS
.IP
.nf
\f[C]
pickfrom = \[dq]!f() { : git man pickfrom; \[rs]
    echo $(git prheader) $(git emph pickfrom);                  : Output command header; \[rs]
    [ $# -ne 1 ] && echo Usage: pickfrom revisions && return 1; : Ensure proper number of arguments; \[rs]
    if ! git stow; then return 1; fi;                           : Call stow alias to temporarily store Workspace; \[rs]
    cmd=\[rs]\[dq]cherry-pick $1\[rs]\[dq];                                     : Set next command; \[rs]
    echo $(git prinfo) cherry-pick $1 $(git prextra $cmd);      : Output next command; \[rs]
    git $cmd;                                                   : Grab changes from first argument; \[rs]
    git mergetooly;                                             : Merge those changes with current HEAD; \[rs]
    cmd=\[rs]\[dq]commit\[rs]\[dq];                                             : Set next command; \[rs]
    echo $(git prinfo) commit $(git prextra $cmd);              : Output next command; \[rs]
    git $cmd;                                                   : Commit merged changeset; \[rs]
    git unstow;                                                 : Call unstow alias to restore Workspace to former condition; \[rs]
    return 0;                                                   : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
