.TH "git alias.uncommit(1)" "" "" "" ""
.hy
.SH NAME
.PP
git uncommit
.SH SYNOPSIS
.PP
git uncommit - uncommit changesets and restore to working copy
.SH DESCRIPTION
.PP
git uncommit is a helper alias to uncommit changesets and restore to
working copy.
.SH EXAMPLES
.IP \[bu] 2
\f[C]git uncommit\f[R]
.IP \[bu] 2
\f[C]git uncommit 2\f[R]
.IP \[bu] 2
\f[C]git uncommit hash\f[R]
.SH SEE ALSO
.PP
squash
.SH DETAILS
.IP
.nf
\f[C]
uncommit = \[dq]!f() { : git man uncommit; \[rs]
    if ! git stowcheck; then return 1; fi;                                              : Call stowcheck alias to see if workspace is ready; \[rs]
    arg=${1:-1};                                                                        : Get argument to uncommit, default to 1; \[rs]
    if git cat-file -e $arg >/dev/null 2>&1; then hash=$arg;                            : The argument is a hash, so convert it; \[rs]
    else hash=\[at]\[ti]$arg; fi;                                                               : The argument is not a hash, so try to make one; \[rs]
    ofile=uncommit.txt;                                                                 : File to store the commit message; \[rs]
    if [ -e $ofile ]; then                                                              : Check to be sure scratch file is available; \[rs]
        echo file $ofile exists, please move;                                           : Output error that scratch file exists; \[rs]
        return 1;                                                                       : Return error code; \[rs]
    fi;                                                                                 : Close if statement; \[rs]
    echo \[rs]\[dq]# Prior log messages from previous git uncommit are below\[rs]\[dq] | tee -a $ofile; : Helpful message; \[rs]
    echo | tee -a $ofile;                                                               : Vertical spacing; \[rs]
    git log $hash..\[at] --format=format:%B | tee -a $ofile;                                : Store the logs of each in the commit message; \[rs]
    git rsoft $hash;                                                                    : Restore changes to the index; \[rs]
    git rmixed;                                                                         : Restore index to the workspace; \[rs]
    return 0;                                                                           : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
