.SH NAME
.PP
git backuprm
.SH SYNOPSIS
.PP
git backuprm - remove all backups from previous backup invocations
.SH DESCRIPTION
.PP
git backup is a helper alias to remove all backups from previous backup
invocations.
.SH EXAMPLES
.IP \[bu] 2
git backuprm
.SH SEE ALSO
.PP
backup backups
.SH DETAILS
.IP
.nf
\f[C]
backuprm = \[dq]!f() { : git man backuprm; \[rs]
    cd \[rs]\[dq]$(git root)\[rs]\[dq]; \[rs]
    bn=$(basename $(pwd)); \[rs]
    rm -f ../$bn.*.tar; \[rs]
}; f\[dq]
\f[R]
.fi
