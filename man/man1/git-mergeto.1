.TH "git alias.mergeto(1)" "" "" "" ""
.hy
.SH NAME
.PP
git mergeto
.SH SYNOPSIS
.PP
git mergeto branch - stow working copy, merge with first argument, then
unstow
.SH DESCRIPTION
.PP
git mergeto is a helper alias to merge HEAD onto another branch.
.IP "1." 3
Ensures that the current HEAD is not a detached HEAD
.IP "2." 3
Ensures that the proper number of arguments have been provided
.IP "3." 3
Ensures that the provided argument is associated with a branch
.IP "4." 3
Calls the stow alias to temporarily store the Workspace
.IP "5." 3
Switch to the target branch for merging
.IP "6." 3
Ensures that the new HEAD after the switch is not a detached HEAD
.IP "7." 3
Execute the merge
.IP "8." 3
Calls the unstow alias to restore the Workspace to its former condition
.SH EXAMPLES
.IP \[bu] 2
\f[C]git mergeto $(git brupstream)\f[R]
.IP \[bu] 2
\f[C]git mergeto master\f[R]
.SH SEE ALSO
.PP
mergefrom finishto rebaseto
.SH DETAILS
.IP
.nf
\f[C]
mergeto = \[dq]!f() { : git man mergeto; \[rs]
    echo $(git prheader) $(git emph mergeto);                       : Output command header; \[rs]
    if ! git attached; then return 1; fi;                           : Ensure that HEAD is not detached HEAD; \[rs]
    [ $# -ne 1 ] && echo Usage: mergeto branch && return 1;         : Ensure proper number of arguments; \[rs]
    PREV=$(git ref);                                                : Store ref of HEAD; \[rs]
    if ! git sref $1; then return 1; fi;                            : Ensure that provided argument is associated with branch; \[rs]
    if ! git stow; then return 1; fi;                               : Call stow alias to temporarily store Workspace; \[rs]
    cmd=\[rs]\[dq]checkout $1\[rs]\[dq];                                            : Set next command; \[rs]
    echo $(git prinfo) checkout $1 branch $(git prextra $cmd);      : Output next command; \[rs]
    git $cmd;                                                       : Switch to target branch for merging; \[rs]
    if ! git attached; then                                         : Ensure that new HEAD after switch is not detached HEAD; \[rs]
        git switch -;                                               : Switch back to prior branch; \[rs]
        git unstow;                                                 : Call unstow alias to restore Workspace to former condition; \[rs]
        echo $(git prerror $1 would be a detached HEAD);            : Output error that target would be detached HEAD; \[rs]
        return 1;                                                   : Return one; \[rs]
    fi;                                                             : Close if statement; \[rs]
    cmd=\[rs]\[dq]merge $PREV\[rs]\[dq];                                            : Set next command; \[rs]
    echo $(git prinfo) merge with $PREV branch $(git prextra $cmd); : Output next command; \[rs]
    if ! git $cmd; then                                             : Execute merge; \[rs]
        git mergetooly;                                             : If there are conflicts; \[rs]
        cmd=\[rs]\[dq]commit\[rs]\[dq];                                             : Call mergetooly alias; \[rs]
        echo $(git prinfo) commit $(git prextra $cmd);              : Set next command; \[rs]
        git $cmd;                                                   : Output next command; \[rs]
    fi;                                                             : Commit merged changeset; \[rs]
    git unstow;                                                     : Call unstow alias to restore Workspace to former condition; \[rs]
    return 0;                                                       : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
