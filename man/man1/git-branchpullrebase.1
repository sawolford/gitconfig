.SH NAME
.PP
git branchpullrebase
.SH SYNOPSIS
.PP
git branchpullrebase branch - stow working copy, check out first
argument, then execute pullrebase
.SH DESCRIPTION
.PP
git branchpullrebase is a helper alias to pullrebase a specific branch.
.SH EXAMPLES
.IP \[bu] 2
git branchpullrebase branch
.SH SEE ALSO
.PP
pullrebase masterpullrebase
.SH DETAILS
.IP
.nf
\f[C]
branchpullrebase = \[dq]!f() { : git man branchpullrebase; \[rs]
    [ $# -ne 1 ] && echo \[aq]Usage: branchpullrebase branch\[aq] && return 1; \[rs]
    if ! git show-ref $1; then echo \[aq]branch not a named ref\[aq]; return 1; fi; \[rs]
    git stowco $1; \[rs]
    git pullrebase; \[rs]
}; f\[dq]
\f[R]
.fi
