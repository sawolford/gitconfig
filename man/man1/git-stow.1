\f[C]
stow = \[dq]!f() { : git man stow; \[rs]
    echo $(git prheader) $(git emph stow);                             : Output command header; \[rs]
    cmd=\[rs]\[dq]status -s\[rs]\[dq];                                                 : Set next command; \[rs]
    echo $(git prinfo) check working copy changes $(git prextra $cmd); : Output next command; \[rs]
    [ -z \[rs]\[dq]$(git $cmd)\[rs]\[dq] ] && return 0;                                : Check to see if there are local changes; \[rs]
    if ! git attached; then return 1; fi;                              : Ensure that HEAD is not detached HEAD; \[rs]
    PREV=$(git ref);                                                   : Store ref of HEAD; \[rs]
    if ! git stowbranch; then return 1; fi;                            : Ensure that nothing is already stowed and checks out temporary _stow branch; \[rs]
    cmd=\[rs]\[dq]add -A\[rs]\[dq];                                                    : Set next command; \[rs]
    echo $(git prinfo) add working copy changes $(git prextra $cmd);   : Output next command; \[rs]
    git $cmd >/dev/null 2>&1;                                          : Add all local changes to Index; \[rs]
    cmd=\[rs]\[dq]commit --no-verify -m stow\[rs]\[dq];                                : Set next command; \[rs]
    echo $(git prinfo) commit stow branch $(git prextra $cmd);         : Output next command; \[rs]
    git $cmd >/dev/null 2>&1;                                          : Commit Index, ignoring pre-commit checks; \[rs]
    cmd=\[rs]\[dq]checkout $PREV\[rs]\[dq];                                            : Set next command; \[rs]
    echo $(git prinfo) checkout $PREV $(git prextra $cmd);             : Output next command; \[rs]
    git $cmd >/dev/null 2>&1;                                          : Check out previous HEAD; \[rs]
    return 0;                                                          : Return zero; \[rs]
}; f\[dq]
