.TH "git alias.smfa(1) User manual" "" "May, 2020" "" ""
.hy
.SH NAME
.PP
git smfa
.SH SYNOPSIS
.PP
git smfa command - iterate over submodules and current directory to
execute shell command
.SH DESCRIPTION
.PP
git smfa is a helper alias to execute shell commands in the current
folder and in each submodule.
.SH EXAMPLES
.IP \[bu] 2
git smfa pwd
.IP \[bu] 2
git smfa \[lq]touch .gitignore\[rq]
.SH SEE ALSO
.PP
smf smg smga
.SH DETAILS
.IP
.nf
\f[C]
smfa = \[dq]!f() { : git man smfa; \[rs]
    [ $# -ne 1 ] && echo \[aq]Usage: smfa command\[aq] && return; \[rs]
    $SHELL -c \[rs]\[dq]$\[at]\[rs]\[dq]; \[rs]
    git smf \[rs]\[dq]$\[at]\[rs]\[dq]; \[rs]
}; f\[dq]
\f[R]
.fi
