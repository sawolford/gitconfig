.TH "git alias.stowco(1)" "" "" "" ""
.hy
.SH NAME
.PP
git stowco
.SH SYNOPSIS
.PP
git stowco branch - stow working copy, checkout first argument, then
unstow
.SH DESCRIPTION
.PP
git stowco is a helper alias to checkout another branch.
.IP "1." 3
Ensures that the proper number of arguments have been provided
.IP "2." 3
Calls the stow alias to temporarily store the Workspace
.IP "3." 3
Checks out the target branch
.IP "4." 3
Calls the unstow alias to restore the Workspace to its former condition
.SH EXAMPLES
.IP \[bu] 2
\f[C]git stowco $(git brupstream)\f[R]
.IP \[bu] 2
\f[C]git stowco master\f[R]
.SH SEE ALSO
.PP
stow unstow stowcob
.SH DETAILS
.IP
.nf
\f[C]
stowco = \[dq]!f() { : git man stowco; \[rs]
    echo $(git prheader) $(git emph stowco);                   : Output command header; \[rs]
    [ $# -ne 1 ] && echo Usage: stowco branch && return 1;     : Ensure proper number of arguments; \[rs]
    if ! git stow; then return 1; fi;                          : Call stow alias to temporarily store Workspace; \[rs]
    cmd=\[rs]\[dq]checkout $1\[rs]\[dq];                                       : Set next command; \[rs]
    echo $(git prinfo) checkout $1 branch $(git prextra $cmd); : Output next command; \[rs]
    git $cmd;                                                  : Check out target branch; \[rs]
    git unstow;                                                : Call unstow alias to restore Workspace to former condition; \[rs]
    return 0;                                                  : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
