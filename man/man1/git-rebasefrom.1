.TH "git alias.rebasefrom(1)" "" "" "" ""
.hy
.SH NAME
.PP
git rebasefrom
.SH SYNOPSIS
.PP
git rebasefrom branch - stow working copy, rebase first argument onto
HEAD, then unstow
.SH DESCRIPTION
.PP
git rebasefrom is a helper alias to rebase another branch onto HEAD.
.IP "1." 3
Ensures that the current HEAD is not a detached HEAD
.IP "2." 3
Ensures that the proper number of arguments have been provided
.IP "3." 3
Stores the ref of HEAD so it can be returned to later
.IP "4." 3
Ensures that the provided argument is associated with a branch
.IP "5." 3
Calls the stow alias to temporarily store the Workspace
.IP "6." 3
Checks out the source branch
.IP "7." 3
Calls the rebcombine alias to repeatedly merge changesets
.IP "8." 3
Checks out the previous HEAD
.IP "9." 3
Calls the unstow alias to restore the Workspace to its former condition
.SH EXAMPLES
.IP \[bu] 2
\f[C]git rebasefrom branch\f[R]
.SH SEE ALSO
.PP
rebaseto finishfrom mergefrom
.SH DETAILS
.IP
.nf
\f[C]
rebasefrom = \[dq]!f() { : git man rebasefrom; \[rs]
    echo $(git prheader) $(git emph rebasefrom);                  : Output command header; \[rs]
    if ! git attached; then return 1; fi;                         : Ensure that HEAD is not detached HEAD; \[rs]
    [ $# -ne 1 ] && echo Usage: rebasefrom branch && return 1;    : Ensure proper number of arguments; \[rs]
    PREV=$(git ref);                                              : Store ref of HEAD; \[rs]
    if ! git sref $1; then return 1; fi;                          : Ensure that provided argument is associated with branch; \[rs]
    if ! git stow; then return 1; fi;                             : Call stow alias to temporarily store Workspace; \[rs]
    cmd=\[rs]\[dq]checkout $1\[rs]\[dq];                                          : Set next command; \[rs]
    echo $(git prinfo) checkout $1 branch $(git prextra $cmd);    : Output next command; \[rs]
    git $cmd;                                                     : Check out source branch; \[rs]
    git rebcombine $PREV;                                         : Call rebcombine alias to repeatedly merge changesets; \[rs]
    cmd=\[rs]\[dq]checkout $PREV\[rs]\[dq];                                       : Set next command; \[rs]
    echo $(git prinfo) checkout $PREV branch $(git prextra $cmd); : Output next command; \[rs]
    git $cmd;                                                     : Check out previous HEAD; \[rs]
    git unstow;                                                   : Call unstow alias to restore Workspace to former condition; \[rs]
    return 0;                                                     : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
