smf = \[dq]!f() { : git man smf; \[rs]
    [ $# -ne 1 ] && echo \[aq]Usage: smf command\[aq] && return; \[rs]
    git sm foreach \[rs]\[dq]$\[at] || true\[rs]\[dq]; \[rs]
}; f\[dq]
