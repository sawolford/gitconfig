.TH "git alias.finishfrom(1)" "" "" "" ""
.hy
.SH NAME
.PP
git finishfrom
.SH SYNOPSIS
.PP
git finishfrom branch - rebase from first argument, fast forward merge,
then delete first argument
.SH DESCRIPTION
.PP
git finishfrom is a helper alias to rebase another branch onto HEAD and
then delete that branch.
.IP "1." 3
Ensures that the current HEAD is not a detached HEAD
.IP "2." 3
Ensures that the proper number of arguments have been provided
.IP "3." 3
Ensures that the provided argument is associated with a branch
.IP "4." 3
Calls the rebasefrom alias to rebase the changesets to the source branch
.IP "5." 3
Calls the mergefrom alias to fast-forward merge the HEAD with the source
branch
.IP "6." 3
Deletes the branch since it is not no longer needed
.SH EXAMPLES
.IP \[bu] 2
\f[C]git finishfrom branch\f[R]
.SH SEE ALSO
.PP
finishto rebasefrom mergefrom
.SH DETAILS
.IP
.nf
\f[C]
finishfrom = \[dq]!f() { : git man finishfrom; \[rs]
    echo $(git prheader) $(git emph finishfrom);                  : Output command header; \[rs]
    if ! git attached; then return 1; fi;                         : Ensure that HEAD is not detached HEAD; \[rs]
    [ $# -ne 1 ] && echo Usage: finishfrom branch && return 1;    : Ensure proper number of arguments; \[rs]
    if ! git sref $1; then return 1; fi;                          : Ensure that provided argument is associated with branch; \[rs]
    cmd=\[rs]\[dq]rebasefrom $1\[rs]\[dq];                                        : Set next command; \[rs]
    echo $(git prinfo) rebase from $1 branch $(git prextra $cmd); : Output next command; \[rs]
    git $cmd;                                                     : Call rebasefrom alias to rebase changesets to source branch; \[rs]
    cmd=\[rs]\[dq]mergefrom $1\[rs]\[dq];                                         : Set next command; \[rs]
    echo $(git prinfo) merge from $1 branch $(git prextra $cmd);  : Output next command; \[rs]
    git $cmd;                                                     : Call mergefrom alias to merge HEAD with source branch; \[rs]
    cmd=\[rs]\[dq]branch -D $1\[rs]\[dq];                                         : Set next command; \[rs]
    echo $(git prinfo) delete $1 branch $(git prextra $cmd);      : Output next command; \[rs]
    git $cmd;                                                     : Delete branch since it is no longer needed; \[rs]
    return 0;                                                     : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
