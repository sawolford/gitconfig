.SH DESCRIPTION
.IP \[bu] 2
git backup - create $(basename $(pwd)).X.tar, where X increases with
each invocation
.IP \[bu] 2
git backuprm - remove all backups from previous backup invocations
.IP \[bu] 2
git backups - list available backups from previous backup invocations
.IP \[bu] 2
git branchpullrebase branch - stow working copy, check out first
argument, then execute pullrebase
.IP \[bu] 2
git charsets - print number of tracked files of each likely charset
.IP \[bu] 2
git filetype - execute unix file command on all tracked files
.IP \[bu] 2
git finishfrom branch - rebase from first argument, fast forward merge,
then delete first argument
.IP \[bu] 2
git finishto branch - rebase to first argument, fast forward merge, then
delete first argument
.IP \[bu] 2
git forceeol - force a file pattern to have a given eol setting
.IP \[bu] 2
git gitbinary - print tracked files that git considers binary
.IP \[bu] 2
git gittext - print tracked files that git considers text
.IP \[bu] 2
git globalhookspath - add core.hooksPath to \[ti]/gitconfig/local
.IP \[bu] 2
git man command - output the man page for a git command in the best
format possible
.IP \[bu] 2
git masterpullrebase branch - execute branchpullrebase on master
.IP \[bu] 2
git mergefrom branch - stow working copy, merge with first argument,
then unstow
.IP \[bu] 2
git mergeto branch - stow working copy, merge with first argument, then
unstow
.IP \[bu] 2
git mimetype - execute unix file \[en]mime command on all tracked files
.IP \[bu] 2
git nonascii - print non-ascii lines in a grep-like way
.IP \[bu] 2
git nonasciiall - print non-ascii lines for all tracked files
.IP \[bu] 2
git notasciilist - list all tracked files with non-ascii characters
.IP \[bu] 2
git pickfrom branch - stow working copy, cherrypick changesets, then
unstow
.IP \[bu] 2
git pullrebase - fetch, then rebase HEAD with its upstream branch
.IP \[bu] 2
git rebasefrom branch - stow working copy, rebase first argument onto
HEAD, then unstow
.IP \[bu] 2
git rebaseto branch - stow working copy, rebase HEAD onto first
argument, then unstow
.IP \[bu] 2
git rewindbase source - move a branch to the common ancestor with its
upstream
.IP \[bu] 2
git smf command - iterate over submodules to execute shell command
.IP \[bu] 2
git smfa command - iterate over submodules and current directory to
execute shell command
.IP \[bu] 2
git smg command - iterate over submodules to execute git command
.IP \[bu] 2
git smga command - iterate over submodules and current directory to
execute git command
.IP \[bu] 2
git squash - squash changesets and recommit
.IP \[bu] 2
git stow - save the workspace state
.IP \[bu] 2
git stowco branch - stow working copy, checkout first argument, then
unstow
.IP \[bu] 2
git stowcob branch - stow working copy, checkout first argument that
tracks second argument, then unstow
.IP \[bu] 2
git stowreco - stow working copy, re-checkout HEAD, then unstow
.IP \[bu] 2
git uncommit - uncommit changesets and restore to working copy
.IP \[bu] 2
git unstow - restore the workspace state
