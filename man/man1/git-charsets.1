.TH "git alias.charsets(1)" "" "" "" ""
.hy
.SH NAME
.PP
git charsets
.SH SYNOPSIS
.PP
git charsets - print number of tracked files of each likely charset
.SH DESCRIPTION
.PP
git charsets is a helper alias to print number of tracked files of each
likely charset
.SH EXAMPLES
.IP \[bu] 2
\f[C]git charsets\f[R]
.SH SEE ALSO
.PP
gittext gitbinary forceeol
.SH DETAILS
.IP
.nf
\f[C]
charsets = \[dq]!f() { : git man charsets; \[rs]
    types=\[aq]binary us-ascii utf-8 iso-8859-1 unknown-8bit utf-16le utf-16be ebcdic\[aq]; : All the charsets likely to be encountered; \[rs]
    maxlen=20;                                                                      : Minimum spacing on output; \[rs]
    for type in $types; do                                                          : Loop over likely charsets; \[rs]
        count=$(git mimetype $type | wc -l);                                        : Count number of files of that charset; \[rs]
        left=$(expr $maxlen - ${#type});                                            : Find spacing required; \[rs]
        printf \[aq]%s%s%d\[rs]n\[aq] $type \[rs]\[dq]$(git repeatstr $left)\[rs]\[dq] $count;                  : Print out the count with spacing; \[rs]
    done;                                                                           : Done with charset; \[rs]
}; f\[dq]
\f[R]
.fi
