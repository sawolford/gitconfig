.TH "git alias.backup(1) User manual" "" "April, 2020" "" ""
.hy
.SH NAME
.PP
git backup
.SH SYNOPSIS
.PP
git backup - create ../$(basename $(pwd)).X.tar, where X increases with
each invocation
.SH DESCRIPTION
.PP
git backup is a helper alias to create a backup tar file of the current
folder.
.SH EXAMPLES
.IP \[bu] 2
git backup
.SH SEE ALSO
.PP
backups backuprm
.SH DETAILS
.IP
.nf
\f[C]
backup = \[dq]!f() { : git man backup; \[rs]
    bn=$(basename $(pwd)); \[rs]
    ii=0; \[rs]
    while true; do \[rs]
        fn=../$bn.$ii.tar; \[rs]
        [ ! -e $fn ] && break; \[rs]
        ii=$((ii + 1)); \[rs]
    done; \[rs]
    tar cf $fn .; \[rs]
    echo $fn; \[rs]
}; f\[dq]
\f[R]
.fi
