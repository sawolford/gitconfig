.SH NAME
.PP
git backup
.SH SYNOPSIS
.PP
git backup - create $(basename $(pwd)).X.tar, where X increases with
each invocation
.SH DESCRIPTION
.PP
git backup is a helper alias to create a backup tar file of the current
folder.
.SH EXAMPLES
.IP \[bu] 2
\f[C]git backup\f[R]
.SH SEE ALSO
.PP
backups backuprm
.SH DETAILS
.IP
.nf
\f[C]
backup = \[dq]!f() { : git man backup;\[rs]
    cd \[rs]\[dq]$(git root)\[rs]\[dq];           : Change directory to root; \[rs]
    bn=$(basename $(pwd));        : Get name of folder for backup file name; \[rs]
    ii=0;                         : Initialize loop variable; \[rs]
    while true; do                : Loop until file does not exist; \[rs]
        fn=$bn.$ii.tar;           : Test backup file name; \[rs]
        [ ! -e ../$fn ] && break; : Test if backup file exists; \[rs]
        ii=$((ii + 1));           : Increment loop variable; \[rs]
    done;                         : Close while loop; \[rs]
    tar cf ../$fn .;              : Tar entire folder; \[rs]
    echo $fn;                     : Output new backup file name; \[rs]
    return 0;                     : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
