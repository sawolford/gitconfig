\f[C]
unstow = \[dq]!f() { : git man unstow \[rs]
    echo $(git prheader) $(git emph unstow);                                     : Output command header; \[rs]
    cmd=\[rs]\[dq]cherry-pick -n _stow\[rs]\[dq];                                                : Set next command; \[rs]
    echo $(git prinfo) cherry-pick changes from stow branch $(git prextra $cmd); : Output next command; \[rs]
    git $cmd >/dev/null 2>&1;                                                    : Grab changes made by previous stow command; \[rs]
    git mergetooly;                                                              : Merge those changes with current HEAD; \[rs]
    cmd=\[rs]\[dq]reset --mixed\[rs]\[dq];                                                       : Set next command; \[rs]
    echo $(git prinfo) reset index to working copy $(git prextra $cmd);          : Output next command; \[rs]
    git $cmd;                                                                    : Reset changes back into Workspace; \[rs]
    cmd=\[rs]\[dq]branch -D _stow\[rs]\[dq];                                                     : Set next command; \[rs]
    echo $(git prinfo) delete stow branch $(git prextra $cmd);                   : Output next command; \[rs]
    git $cmd >/dev/null 2>&1;                                                    : Delete temporary _stow branch; \[rs]
    return 0;                                                                    : Return zero; \[rs]
}; f\[dq]
}; f\[dq]
