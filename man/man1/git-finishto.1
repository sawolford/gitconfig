.TH "git alias.finishto(1)" "" "" "" ""
.hy
.SH NAME
.PP
git finishto
.SH SYNOPSIS
.PP
git finishto branch - rebase to first argument, fast forward merge, then
delete first argument
.SH DESCRIPTION
.PP
git finishto is a helper alias to rebase HEAD onto another branch and
then delete that branch.
.IP "1." 3
Ensures that the current HEAD is not a detached HEAD
.IP "2." 3
Ensures that the proper number of arguments have been provided
.IP "3." 3
Stores the ref of HEAD so it can be deleted at the end
.IP "4." 3
Ensures that the provided argument is associated with a branch
.IP "5." 3
Calls the rebaseto alias to rebase the changesets to the target branch
.IP "6." 3
Calls the mergeto alias to fast-forward merge the HEAD with the target
branch
.IP "7." 3
Deletes the branch since it is not no longer needed
.SH EXAMPLES
.IP \[bu] 2
\f[C]git finishto $(git brupstream)\f[R]
.IP \[bu] 2
\f[C]git finishto master\f[R]
.SH SEE ALSO
.PP
finishfrom rebaseto mergeto
.SH DETAILS
.IP
.nf
\f[C]
finishto = \[dq]!f() { : git man finishto; \[rs]
    echo $(git prheader) $(git emph finishto);                  : Output command header; \[rs]
    if ! git attached; then return 1; fi;                       : Ensure that HEAD is not detached HEAD; \[rs]
    [ $# -ne 1 ] && echo Usage: finishto branch && return 1;    : Ensure proper number of arguments; \[rs]
    PREV=$(git ref);                                            : Store ref of HEAD so it can be deleted at end; \[rs]
    if ! git sref $1; then return 1; fi;                        : Ensure that provided argument is associated with branch; \[rs]
    cmd=\[rs]\[dq]rebaseto $1\[rs]\[dq];                                        : Set next command; \[rs]
    echo $(git prinfo) rebase to $1 branch $(git prextra $cmd); : Output next command; \[rs]
    git $cmd;                                                   : Call rebaseto alias to rebase changesets to target branch; \[rs]
    cmd=\[rs]\[dq]mergeto $1\[rs]\[dq];                                         : Set next command; \[rs]
    echo $(git prinfo) merge to $1 branch $(git prextra $cmd);  : Output next command; \[rs]
    git $cmd;                                                   : Call mergeto alias to merge HEAD with target branch; \[rs]
    cmd=\[rs]\[dq]branch -D $PREV\[rs]\[dq];                                    : Set next command; \[rs]
    echo $(git prinfo) delete $PREV branch $(git prextra $cmd); : Output next command; \[rs]
    git $cmd;                                                   : Delete branch since it is no longer needed; \[rs]
    return 0;                                                   : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
