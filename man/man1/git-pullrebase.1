.TH "git alias.pullrebase(1)" "" "" "" ""
.hy
.SH NAME
.PP
git pullrebase
.SH SYNOPSIS
.PP
git pullrebase - fetch, then rebase HEAD with its upstream branch
.SH DESCRIPTION
.PP
git pullrebase is a helper alias to rebase HEAD with its upstreaem.
.IP "1." 3
Ensures that the current HEAD is not a detached HEAD
.IP "2." 3
Ensures that the current branch is associated with an upstream branch
.IP "3." 3
Downloads changesets from the origin remote
.IP "4." 3
Stores the upstream branch name associated with HEAD in a variable
.IP "5." 3
Calls the rebaseto with a target of the upstream branch associated with
the current HEAD
.SH EXAMPLES
.IP \[bu] 2
\f[C]git pullrebase\f[R]
.SH SEE ALSO
.PP
rebaseto
.SH DETAILS
.IP
.nf
\f[C]
pullrebase = \[dq]!f() { : git man pullrebase; \[rs]
    echo $(git prheader) $(git emph pullrebase);                                 : Output command header; \[rs]
    if ! git attached; then return 1; fi;                                        : Ensure that HEAD is not detached HEAD; \[rs]
    cmd=\[rs]\[dq]rev-parse --abbrev-ref \[at]{u}\[rs]\[dq];                                         : Set next command; \[rs]
    echo $(git prinfo) check for upstream on current branch $(git prextra $cmd); : Output next command; \[rs]
    if ! git $cmd >/dev/null 2>&1; then                                          : Ensure that current branch is associated with upstream branch; \[rs]
        echo $(git prerror current branch has no upstream);                      : Error if current branch is not associated with upstream branch; \[rs]
        return 1;                                                                : Return error code; \[rs]
    fi;                                                                          : Close if statement; \[rs]
    cmd=\[rs]\[dq]fetch\[rs]\[dq];                                                               : Set next command; \[rs]
    echo $(git prinfo) fetch $(git prextra $cmd);                                : Output next command; \[rs]
    git $cmd;                                                                    : Download changesets from origin remote; \[rs]
    UPSTREAM=$(git rev-parse --abbrev-ref \[at]{u});                                 : Store upstream branch name associated with HEAD in variable; \[rs]
    git rebaseto $UPSTREAM;                                                      : Call rebaseto alias on upstream branch associated with HEAD; \[rs]
    return 0;                                                                    : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
