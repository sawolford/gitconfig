.TH "git alias.man(1) User manual" "" "May, 2020" "" ""
.hy
.SH NAME
.PP
git man
.SH SYNOPSIS
.PP
git man command - output the man page for a git command in the best
format possible
.SH DESCRIPTION
.PP
git man is a helper alias to output the man page for a git command in
the best format available.
.SH EXAMPLES
.IP \[bu] 2
git man man
.IP \[bu] 2
git man rebaseto
.SH SEE ALSO
.SH DETAILS
.IP
.nf
\f[C]
man = \[dq]!f() { : git man man; \[rs]
    [ $# -ne 1 ] && echo \[aq]Usage: man command\[aq] && return; \[rs]
    command() { sed \[aq]/D.*E.*T.*A.*I.*L.*S/q\[aq] | sed \[aq]$d\[aq] | grep -v \[aq]\[ha]$\[aq]; }; \[rs]
    docpath=\[ti]/gitconfig/man; \[rs]
    htmlpath=\[ti]/gitconfig/html; \[rs]
    if git ingitbash; then \[rs]
        docpath=$(cygpath -m $docpath); \[rs]
        htmlpath=$(cygpath -m $htmlpath); \[rs]
    fi; \[rs]
    if git dohtml; then \[rs]
        git web--browse \[rs]\[dq]$htmlpath/git-$1.html\[rs]\[dq]; \[rs]
    elif git haveman; then \[rs]
        export MANPATH=$docpath; \[rs]
        man git-$1 | tail -n +2 | command; \[rs]
    elif git havepandoc; then \[rs]
        pandoc -f man \[rs]\[dq]$docpath/man1/git-$1.1\[rs]\[dq] -t plain | command; \[rs]
    else \[rs]
        cat \[rs]\[dq]$docpath/man1/git-$1.1\[rs]\[dq] | sed \[aq]s,\[ha]\[rs]\[rs].SH ,,\[aq] | grep -v \[aq]\[ha]\[rs]\[rs].\[aq] | command; \[rs]
    fi; \[rs]
} ; f\[dq]
\f[R]
.fi
