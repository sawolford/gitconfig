.TH "git alias.mergefrom(1)" "" "" "" ""
.hy
.SH NAME
.PP
git mergefrom
.SH SYNOPSIS
.PP
git mergefrom branch - stow working copy, merge with first argument,
then unstow
.SH DESCRIPTION
.PP
git mergefrom is a helper alias to merge another branch onto HEAD.
.IP "1." 3
Ensures that the current HEAD is not a detached HEAD
.IP "2." 3
Ensures that the proper number of arguments have been provided
.IP "3." 3
Stores the ref of HEAD so it can be returned to later
.IP "4." 3
Ensures that the provided argument is associated with a branch
.IP "5." 3
Calls the stow alias to temporarily store the Workspace
.IP "6." 3
Executes the merge
.IP "7." 3
Calls the unstow alias to restore the Workspace to its former condition
.SH EXAMPLES
.IP \[bu] 2
\f[C]git mergefrom branch\f[R]
.SH SEE ALSO
.PP
mergeto finishfrom rebasefrom
.SH DETAILS
.IP
.nf
\f[C]
mergefrom = \[dq]!f() { : git man mergefrom; \[rs]
    echo $(git prheader) $(git emph mergefrom);                  : Output command header; \[rs]
    if ! git attached; then return 1; fi;                        : Ensure that HEAD is not detached HEAD; \[rs]
    [ $# -ne 1 ] && echo Usage: mergefrom branch && return 1;    : Ensure proper number of arguments; \[rs]
    PREV=$(git ref);                                             : Store ref of HEAD; \[rs]
    if ! git sref $1; then return 1; fi;                         : Ensure that provided argument is associated with branch; \[rs]
    if ! git stow; then return 1; fi;                            : Call stow alias to temporarily store Workspace; \[rs]
    cmd=\[rs]\[dq]merge $1\[rs]\[dq];                                            : Set next command; \[rs]
    echo $(git prinfo) merge with $1 branch $(git prextra $cmd); : Output next command; \[rs]
    if ! git $cmd; then                                          : Execute merge; \[rs]
        git mergetooly;                                          : Call mergetooly alias to resolve conflicts; \[rs]
        cmd=\[rs]\[dq]commit\[rs]\[dq];                                          : Set next command; \[rs]
        echo $(git prinfo) commit $(git prextra $cmd);           : Output next command; \[rs]
        git $cmd;                                                : Commit merged changeset; \[rs]
    fi;                                                          : Close if statement; \[rs]
    git unstow;                                                  : Call unstow alias to restore Workspace to former condition; \[rs]
    return 0;                                                    : Return zero; \[rs]
}; f\[dq]
\f[R]
.fi
