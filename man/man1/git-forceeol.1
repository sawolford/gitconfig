.SH NAME
.PP
git forceeol
.SH SYNOPSIS
.PP
git forceeol - force a file pattern to have a given eol setting
.SH DESCRIPTION
.PP
git forceeol is a helper alias to force a file pattern to have a given
eol setting.
.SH EXAMPLES
.IP \[bu] 2
\f[C]git forceeol \[aq]*.scn\[aq] crlf\f[R]
.IP \[bu] 2
\f[C]git forceeol \[aq]*.sh\[aq] lf\f[R]
.SH SEE ALSO
.PP
gitbinary gittext charsets
.SH DETAILS
.IP
.nf
\f[C]
forceeol = \[dq]!f() { : git man forceeol; \[rs]
    LOCALFILE=.git/info/attributes;                                     : Filename to write to; \[rs]
    if [ $# -ne 2 ]; then echo Usage: forceeol match eol; return 1; fi; : Ensure proper number of arguments; \[rs]
    grep \[rs]\[dq]$1 text eol=$2\[rs]\[dq] $LOCALFILE >/dev/null 2>&1 && return;       : Ensure that config has not already been set \[rs]
    echo \[rs]\[dq]$1\[rs]\[dq] text eol=$2 | tee -a $LOCALFILE;                        : Write the attribute to the proper local file; \[rs]
};f \[dq]
\f[R]
.fi
