[mergetool]
	trustExitCode = true
	keepBackup = false
[diff]
	tool = icdiff
[difftool "icdiff"]
	cmd = icdiff --head=5000 --highlight --line-numbers -L \"$BASE\" -L \"$REMOTE\" \"$LOCAL\" \"$REMOTE\"
[pager]
	diffc = true
	dtmc = false
	dtic = true
	dtvc = false
	dtm = false
	dti = true
	dtv = false
