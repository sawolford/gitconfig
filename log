[log]
    abbrevCommit = true
    date = relative
    decorate = short
    graphColors = cyan,magenta,yellow
[color "decorate"]
    branch = green
    HEAD = cyan
    remoteBranch = red
    tag = blue
    stash = yellow
[pretty]
    pretty = tformat:%C(auto)%h%Creset %C(bold blue)%<(16)%an%C(reset) %C(bold magenta)%<(16)%ch%C(reset) %C(auto)%d%C(reset) %s
    minimal = format:%h:%ct:%cD
    hash = format:%h
