[alias]
	# config
	ruser = !git config --local --unset user.name && git config --local --unset user.email
	# alias
	alias = !git config --list | grep alias
	aliasg = !git config --list | grep alias | grep
	# branch
	remaster = branch --set-upstream-to=origin/master master
	blog = log --left-right
	branches = branch -a
	branchc = rev-parse --abbrev-ref HEAD
	branchd = branch -d
	brancht = branch -t
	bcontains = branch --contains
	# bundle
	bundlec = "!f() { \
		git bundle create $1 $2 HEAD~$3..$4; \
	}; f"
	bundlev = bundle verify
	bundlef = "!f() { \
		git fetch $1 $2:$(basename $1)-$2; \
	}; f"
	# diff
	dtk = difftool --tool=kdiff3 -y
	dtm = difftool --tool=meld -y
	dti = difftool --tool=icdiff -y
	dtv = difftool --tool=vimdiff -y
	diffc = diff --cached
	dtkc = difftool --tool=kdiff3 -y --cached
	dtmc = difftool --tool=meld -y --cached
	dtic = difftool --tool=icdiff -y --cached
	dtvc = difftool --tool=vimdiff -y --cached
	dtkr = "!f() { \
		git difftool --tool=kdiff3 -y $1^..$1; \
	}; f"
	dtmr = "!f() { \
		git difftool --tool=meld -y $1^..$1; \
	}; f"
	dtir = "!f() { \
		git difftool --tool=icdiff -y $1^..$1; \
	}; f"
	dtvr = "!f() { \
		git difftool --tool=vimdiff -y $1^..$1; \
	}; f"
	# glog
	glv = log --graph --pretty=short --left-right
	glva = glv --all --reflog
	glt = log --graph --pretty=format:'%Cred%h%Creset %C(bold blue)%<(16)%an%Creset %Cgreen%<(16)%cr%Creset %s%C(yellow)%d%Creset' --abbrev-commit --left-right
	glta = !git glt --all --reflog
	glt1 = !git glt -n 1
	glt5 = !git glt -n 5
	glt10 = !git glt -n 10
	glv = log --name-status
	glv1 = !git glv -n 1
	# hg
	bco = checkout -b
	ci = commit
	cia = commit -a
	addi = add --interactive
	cii = commit --interactive
	co = checkout
	di = diff
	heads = show-ref --heads
	in = !git fetch && git log --left-right ..origin/master
	incoming = !git fetch && git log --left-right ..origin/master
	out = !git fetch && git log --left-right origin/master..
	outgoing = !git fetch && git log --left-right origin/master..
	paths = remote -v
	st = status --short
	cst = !git -c color.status=always status --short
	purge = clean -fd
	showconfig = config --list
	showconfigg = !git config --list | grep
	schemes = !git showconfig | grep ^url
	manifest = ls-tree -r --name-only --full-tree HEAD
	# merge
	mergec = merge --no-ff
	mergef = merge
	mergea = merge --abort
	mergem = mergetool --tool=meld -y
	mergek = mergetool --tool=kdiff3 -y
	# misc
	addu = add -u .
	rsho = remote set-head origin
	checkpoint = !git ls-files -z | xargs -0 git add
	# push
	pushuu  = push --set-upstream
	pushu = !git pushuu origin
	pushdd = push --delete 
	pushd = !git pushdd origin
	rebasea = rebase --abort
	rebasec = rebase --continue
	# reset
	rhard = reset --hard
	rmixed = reset --mixed
	rsoft = reset --soft
	# strip
	stripbare = "!f() { \
		git update-ref HEAD HEAD^; \
	}; f"
	strip = "!f() { \
		git reset --hard $1^; \
	}; f"
	dangling = fsck --no-reflogs
	cleanup = !git reflog expire --expire-unreachable=now --all && git gc --prune=now
	# stash
	stpush = stash
	stpop = stash pop
	stlist = stash list
	stshow = stash show
	stdrop = stash drop
