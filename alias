[alias]
	# config
	ruser = !git config --local --unset user.name && git config --local --unset user.email
	hookspath = !git config --local core.hooksPath "~/gitconfig/hooks"
	globalhookspath = "!f() { \
		LOCALFILE=~/gitconfig/local; \
        grep 'hooksPath=\"~/gitconfig/hooks\"' $LOCALFILE >/dev/null && return 1; \
		echo '' >> $LOCALFILE; \
		echo '[core]' >> $LOCALFILE; \
        echo '\thooksPath=\"~/gitconfig/hooks\"' >> $LOCALFILE; \
    }; f"
	# alias
	alias = !git config --list | grep alias
	aliasg = !git config --list | grep alias | grep
	# branch
	resetmaster = branch --set-upstream-to=origin/master master
	blog = log --left-right
	branches = branch -a
	branchc = rev-parse --abbrev-ref HEAD
	branchu = rev-parse --abbrev-ref --symbolic-full-name @{u}
	branchd = branch -d
	brancht = branch -t
	bcontains = branch --contains
	# bundle
	bundlec = "!f() { \
		git bundle create $1 $2 HEAD~$3..$4; \
	}; f"
	bundlev = bundle verify
	bundlef = "!f() { \
		git fetch $1 $2:$(basename $1)-$2; \
	}; f"
	# diff
	dtk = difftool --tool=kdiff3 -y
	dtm = difftool --tool=meld -y
	dti = difftool --tool=icdiff -y
	dtv = difftool --tool=vimdiff -y
	diffc = diff --cached
	dtkc = difftool --tool=kdiff3 -y --cached
	dtmc = difftool --tool=meld -y --cached
	dtic = difftool --tool=icdiff -y --cached
	dtvc = difftool --tool=vimdiff -y --cached
	dtkr = "!f() { \
		git difftool --tool=kdiff3 -y $1^..$1; \
	}; f"
	dtmr = "!f() { \
		git difftool --tool=meld -y $1^..$1; \
	}; f"
	dtir = "!f() { \
		git difftool --tool=icdiff -y $1^..$1; \
	}; f"
	dtvr = "!f() { \
		git difftool --tool=vimdiff -y $1^..$1; \
	}; f"
	# glog
	glv = log --graph --pretty=short --left-right
	glva = glv --all --reflog
	glt = log --graph --pretty=format:'%Cred%h%Creset %C(bold blue)%<(16)%an%Creset %Cgreen%<(16)%cr%Creset %C(auto)%d%Creset %s' --abbrev-commit --left-right
	glta = !git glt --all --reflog
	glt1 = !git glt -n 1
	glta1 = !git glta -n 1
	glt5 = !git glt -n 5
	glta5 = !git glta -n 5
	glt10 = !git glt -n 10
	glta10 = !git glta -n 10
	glv = log --name-status
	glv1 = !git glv -n 1
	# hg
	cob = checkout -b
	ci = commit
	cia = commit -a
	addi = add --interactive
	cii = commit --interactive
	co = checkout
	di = diff
	heads = show-ref --heads
	in = !git fetch && git log --left-right ..@{u}
	incoming = !git fetch && git log --left-right ..@{u}
	out = !git fetch && git log --left-right @{u}..
	outgoing = !git fetch && git log --left-right @{u}..
	paths = remote -v
	st = status --short
	cst = !git -c color.status=always status --short
	purge = clean -fd
	showconfig = config --list
	showconfigg = !git config --list | grep
	schemes = !git showconfig | grep ^url
	manifest = ls-tree -r --name-only --full-tree HEAD
	# merge
	mergec = merge --no-ff
	mergef = merge
	mergea = merge --abort
	mergem = mergetool --tool=meld -y
	mergek = mergetool --tool=kdiff3 -y
	# misc
	addu = add -u .
	rsho = remote set-head origin
	checkpoint = !git ls-files -z | xargs -0 git add
	# push
	pushuu  = push --set-upstream
	pushu = !git pushuu origin
	pushdd = push --delete 
	pushd = !git pushdd origin
	rebasea = rebase --abort
	rebasec = rebase --continue
	# reset
	rhard = reset --hard
	rmixed = reset --mixed
	rsoft = reset --soft
	# strip
	stripbare = update-ref HEAD HEAD^
	strip = "!f() { \
		git reset --hard $1^; \
	}; f"
	dangling = fsck --no-reflogs
	cleanup = reflog expire --expire=now --all
	# stash
	stpush = stash
	stpop = stash pop
	stlist = stash list
	stshow = stash show
	stdrop = stash drop
	# download
	mtool = mergetool -y
	rebcont = rebase --continue
	rebskip = rebase --skip
	combine = "!f() { \
		git mtool; \
		if test -n "$(git status --porcelain)" 2>/dev/null; then git rebskip; else git rebcont; fi; \
	}; f"
	rebcombine = "!f() { \
		[ $# -ne 1 ] && echo 'Usage: rebcombine <branch>' && return 1; \
		if git rebase $1; then return; fi; \
		while ! git combine; do true; done; \
	}; f"
	stow = "!f() { \
		[ -z \"$(git status -s)\" ] && return; \
		if ! git symbolic-ref HEAD; then echo 'on detached head'; return 1; fi; \
		PREV=$(git symbolic-ref HEAD | cut -d/ -f3-); \
		if ! git checkout -b _stow; then echo 'already stowed'; return 1; fi; \
		git add -A; \
		git commit -m stow; \
		git checkout \"$PREV\"; \
	}; f"
	unstow = "!f() { \
		git cherry-pick -n _stow; \
		git mtool; \
		git reset --mixed; \
		git branch -D _stow; \
	}; f"
	stowco = "!f() { \
		[ $# -ne 1 ] && echo 'Usage: stowco <branch>' && return 1; \
		if ! git stow; then return 1; fi; \
		git co $1; \
		git unstow; \
	}; f"
	rebaseto = "!f() { \
		if ! git symbolic-ref HEAD; then echo 'on detached head'; return 1; fi; \
		[ $# -ne 1 ] && echo 'Usage: rebaseto <branch>' && return 1; \
		if ! git show-ref $1; then echo 'branch not a named ref'; return 1; fi; \
		if ! git stow; then return 1; fi; \
		git rebcombine $1; \
		git unstow; \
	}; f"
	rebasefrom = "!f() { \
		if ! git symbolic-ref HEAD; then echo 'on detached head'; return 1; fi; \
		[ $# -ne 1 ] && echo 'Usage: rebasefrom <branch>' && return 1; \
		PREV=$(git symbolic-ref HEAD | cut -d/ -f3-); \
		if ! git show-ref $1; then echo 'branch not a named ref'; return 1; fi; \
		if ! git stow; then return 1; fi; \
		git co $1; \
		git rebcombine $PREV; \
		git co $PREV; \
		git unstow; \
	}; f"
	mergeto = "!f() { \
		if ! git symbolic-ref HEAD; then echo 'on detached head'; return 1; fi; \
		[ $# -ne 1 ] && echo 'Usage: mergeto <branch>' && return 1; \
		PREV=$(git symbolic-ref HEAD | cut -d/ -f3-); \
		if ! git show-ref $1; then echo 'branch not a named ref'; return 1; fi; \
		if ! git stow; then return 1; fi; \
		git co $1; \
		if ! git merge $PREV; then git mtool; git ci; fi; \
		git unstow; \
	}; f"
	mergefrom = "!f() { \
		if ! git symbolic-ref HEAD; then echo 'on detached head'; return 1; fi; \
		[ $# -ne 1 ] && echo 'Usage: mergefrom <branch>' && return 1; \
		PREV=$(git symbolic-ref HEAD | cut -d/ -f3-); \
		if ! git show-ref $1; then echo 'branch not a named ref'; return 1; fi; \
		if ! git stow; then return 1; fi; \
		if ! git merge $1; then git mtool; git ci; fi; \
		git unstow; \
	}; f"
	finishto = "!f() { \
		if ! git symbolic-ref HEAD; then echo 'on detached head'; return 1; fi; \
		[ $# -ne 1 ] && echo 'Usage: finishto <branch>' && return 1; \
		PREV=$(git symbolic-ref HEAD | cut -d/ -f3-); \
		if ! git show-ref $1; then echo 'branch not a named ref'; return 1; fi; \
		git rebaseto $1; \
		git mergeto $1; \
		git branch -d $PREV; \
	}; f"
	finishfrom = "!f() { \
		if ! git symbolic-ref HEAD; then echo 'on detached head'; return 1; fi; \
		[ $# -ne 1 ] && echo 'Usage: finishfrom <branch>' && return 1; \
		if ! git show-ref $1; then echo 'branch not a named ref'; return 1; fi; \
		git rebasefrom $1; \
		git mergefrom $1; \
		git branch -d $1; \
	}; f"
	download = "!f() { \
		if ! git symbolic-ref HEAD; then echo 'on detached head'; return 1; fi; \
		if ! git rev-parse --abbrev-ref @{u}; then echo 'no upstream branch'; return 1; fi; \
		git fetch; \
		UPSTREAM=$(git rev-parse --abbrev-ref @{u}); \
		git rebaseto $UPSTREAM; \
	}; f"
	pickfrom = "!f() { \
		[ $# -ne 1 ] && echo 'Usage: rebasefrom <revision(s)>' && return 1; \
		if ! git stow; then return 1; fi; \
		git cherry-pick $1; \
		git mtool; \
		git ci; \
		git unstow; \
	}; f"
