[color]
	ui = true
	decorate = short
	status = auto
[core]
	sshCommand = "ssh -q"
	pager = less
	autocrlf = false
	excludesFile = ~/gitconfig/ignore
[fetch]
	prune = true
[pager]
	dtis = true
	man = true
[pull]
	ff = only
[merge]
	ff = only
[push]
	default = simple
[init]
	defaultBranch = main
[tar]
	umask = 0022
